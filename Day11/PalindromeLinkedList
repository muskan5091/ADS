class Solution {
    public boolean isPalindrome(ListNode head) {
        
        if(head == null || head.next == null)
            return true;
        
        ListNode slow = head;
        ListNode fast = head;
        
        // Find middle
        while(fast != null && fast.next != null){
            slow = slow.next;
            fast = fast.next.next;
        }
        
        // Reverse second half
        ListNode prev = null;
        while(slow != null){
            ListNode next = slow.next;
            slow.next = prev;
            prev = slow;
            slow = next;
        }
        
        // Compare both halves
        ListNode first = head;
        ListNode second = prev;
        
        while(second != null){
            if(first.val != second.val)
                return false;
            
            first = first.next;
            second = second.next;
        }
        
        return true;
    }
}
